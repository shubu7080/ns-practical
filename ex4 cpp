#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <string.h>

long int p, q, n, t, e, d;
char msg[100];

// Function to check prime
int isPrime(long int num) {
    if (num < 2) return 0;
    for (int i = 2; i <= sqrt(num); i++) {
        if (num % i == 0) return 0;
    }
    return 1;
}

// Function to find gcd
long int gcd(long int a, long int b) {
    while (b != 0) {
        long int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

// Function to find modular inverse
long int modInverse(long int e, long int phi) {
    long int d = 1;
    while ((e * d) % phi != 1) {
        d++;
    }
    return d;
}

// Modular exponentiation
long int modPow(long int base, long int exp, long int mod) {
    long int result = 1;
    base = base % mod;
    while (exp > 0) {
        result = (result * base) % mod;
        exp--;
    }
    return result;
}

int main() {
    printf("Enter first prime number: ");
    scanf("%ld", &p);

    if (!isPrime(p)) {
        printf("Invalid prime number\n");
        return 1;
    }

    printf("Enter second prime number: ");
    scanf("%ld", &q);

    if (!isPrime(q) || p == q) {
        printf("Invalid prime number\n");
        return 1;
    }

    printf("Enter message (lowercase only): ");
    scanf("%s", msg);

    n = p * q;
    t = (p - 1) * (q - 1);

    // Choose e
    for (e = 2; e < t; e++) {
        if (gcd(e, t) == 1) break;
    }

    // Find d
    d = modInverse(e, t);

    printf("Public Key (e, n): (%ld, %ld)\n", e, n);
    printf("Private Key (d, n): (%ld, %ld)\n", d, n);

    // Encryption
    printf("Encrypted message: ");
    long int encrypted[100];

    for (int i = 0; msg[i] != '\0'; i++) {
        long int m = msg[i] - 96;
        encrypted[i] = modPow(m, e, n);
        printf("%ld ", encrypted[i]);
    }

    // Decryption
    printf("\nDecrypted message: ");
    for (int i = 0; msg[i] != '\0'; i++) {
        long int decrypted = modPow(encrypted[i], d, n);
        printf("%c", (char)(decrypted + 96));
    }

    printf("\n");
    return 0;
}
